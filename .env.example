# ===========================================
# loain (앱 레포) 환경변수 예시
# 실제 값은 절대 커밋하지 마세요!
# ===========================================

# ---- 로스트아크 API ----
LOSTARK_API_KEY=your_lostark_api_key_here
LOSTARK_API_BASE_URL=https://developer-lostark.game.onstove.com

# ---- FastAPI 백엔드 ----
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,https://loain.kr

# ---- PostgreSQL ----
DATABASE_URL=postgresql://loain:password@localhost:5432/loain

# ---- Redis (캐싱) ----
REDIS_URL=redis://localhost:6379

# ---- Next.js 프론트엔드 ----
NEXT_PUBLIC_API_URL=http://localhost:8000
